{
    "extends": [
        "next/core-web-vitals",
        "plugin:storybook/recommended"
    ],
    "rules": {
        "react/jsx-indent": [
            2,
            4
        ],
        "react/jsx-indent-props": [
            2,
            4
        ],
        "indent": [
            2,
            4
        ],
        "react/jsx-filename-extension": [
            2,
            {
                "extensions": [
                    ".js",
                    ".ts",
                    ".jsx",
                    ".tsx"
                ]
            }
        ],
        "eol-last": [
            "error",
            "always"
        ],
        "semi": "off",
        "quotes": [
            "error",
            "single"
        ],
        "object-curly-spacing": ["error", "always"]
    }
}
